# MongoDB connection string (get from MongoDB Atlas)
MONGODB_URI=mongodb+srv://waterline_admin:PASSWORD@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# JWT secret (use a strong random string)
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# Server port
PORT=5000

# Node environment
NODE_ENV=development

# Admin JWT secret (for admin operations)
ADMIN_JWT_SECRET=admin_super_secret_key_here
